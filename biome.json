{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "linter": {
    "rules": {
      "preset": "recommended",
      "complexity": {
        "useArrowFunction": "error"
      },
      "nursery": {
        "useExplicitReturnType": "error"
      },
      "style": {
        "noNonNullAssertion": "error",
        "useConsistentArrowReturn": "warn"
      },
      "suspicious": {
        "noConsole": "error",
        "noExplicitAny": "error",
        "noTsIgnore": "error"
      }
    }
  }
}
