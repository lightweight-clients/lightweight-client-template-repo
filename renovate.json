{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "group:all"
  ],
  "baseBranchPatterns": [
    "master"
  ],
  "dependencyDashboard": true,
  "schedule": [
    "* 6 * * 1"
  ],
  "timezone": "UTC",
  "prHourlyLimit": 0,
  "prConcurrentLimit": 1,
  "packageRules": [
    {
      "description": "Automerge the weekly dependency update after tests pass",
      "matchPackageNames": [
        "*"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "squash",
      "ignoreTests": false
    }
  ]
}
